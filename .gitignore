# ==============================================================================
# MLOps & Graph Engineering .gitignore (Task 3: Neo4j) by IRONKAGE
# ==============================================================================

# ------------------------------------------------------------------------------
# СЕКРЕТИ ТА КОНФІГУРАЦІЇ (КРИТИЧНО!)
# ------------------------------------------------------------------------------
# Ніколи не комітимо паролі від бази даних (Neo4j Aura / Local Docker/Kaggle)
.env
.env.*
!*.env.example

# ------------------------------------------------------------------------------
# ДАНІ, ДАТАСЕТИ ТА АРТЕФАКТИ (MovieLens)
# ------------------------------------------------------------------------------
# Ігноруємо завантажені архіви та сирі файли (.dat)
data/
*.zip

# 🛡️ КРИТИЧНО ДЛЯ NEO4J DOCKER:
# Ігноруємо згенеровані CSV-файли, щоб не пушити мільйони рядків у Git
# АЛЕ саму папку `import/` залишаємо (через .gitkeep), бо Docker
# шукатиме її при старті для монтування тому ./import:/var/lib/neo4j/import
import/*
!import/.gitkeep

# ------------------------------------------------------------------------------
# ІНФРАСТРУКТУРА (Neo4j Docker Volumes)
# ------------------------------------------------------------------------------
# Якщо томи бази даних або логи монтуються локально (наприклад, для дебагу)
neo4j_data/
neo4j_logs/
plugins/

# ------------------------------------------------------------------------------
# PYTHON (ETL-ядро, Streamlit Dashboard)
# ------------------------------------------------------------------------------
# Кеш скомпільованих файлів
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Кеш ML-моделей (Hugging Face та інші)
.cache/

# Віртуальні середовища
venv/
venv-intel/
env/
.venv/

# Логи пакетного менеджера та Streamlit
pip-log.txt
pip-delete-this-directory.txt
.streamlit/

# ------------------------------------------------------------------------------
# UI АРТЕФАКТИ (Streamlit / PyVis)
# ------------------------------------------------------------------------------
# Ігноруємо згенеровані інтерактивні графи та їхні JS/CSS залежності
dashboard/*.html
dashboard/lib/
# На випадок, якщо PyVis випадково згенерує їх у корені
*.html
!index.html # Якщо колись з'явиться кастомний фронтенд

# ------------------------------------------------------------------------------
# DATA SCIENCE / ML ДОДАТКОВЕ
# ------------------------------------------------------------------------------
# Jupyter Notebook чекпоінти
.ipynb_checkpoints/
# Бінарні ваги ML-моделей (якщо колись вирішите зберігати локально)
*.pt
*.safetensors
*.npy

# ------------------------------------------------------------------------------
# ЛОГИ ТА ТИМЧАСОВІ ФАЙЛИ
# ------------------------------------------------------------------------------
*.log
.temp/
.tmp/
.dynamic_profile

# ------------------------------------------------------------------------------
# СЕРЕДОВИЩА РОЗРОБКИ (IDE) ТА ОС
# ------------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
