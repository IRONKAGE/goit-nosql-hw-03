# ==============================================================================
# 🌍 ENVIRONMENT VARIABLES (MovieLens Graph Recommendation Platform) by IRONKAGE
# ==============================================================================
# УВАГА: Файл .env додано до .gitignore.
# Заповніть цей шаблон реальними даними та збережіть як .env

# --- 1. Режим роботи (Яку базу використовують Python-скрипти) ---
# Доступні значення: local (Docker) або cloud (Aura)
ACTIVE_ENV=local  # 'local' для локальної бази або 'cloud' для хмарної (Aura)

# --- 2. Налаштування інфраструктури Docker (compose.yml) ---
# Доступні значення:
#   - standalone (1 легка нода, Community Edition)
#   - cluster (3-Node High Availability Raft Cluster, Enterprise Edition)
COMPOSE_PROFILES=cluster

# Рівень тестування кластера (Healthcheck SRE Probing)
# Доступні значення: local (легкий HTTP-пінг) або prod (глибокий Cypher-shell тест)
DEPLOY_ENV=local

# Креди для ініціалізації та захисту локальної бази даних
NEO4J_LOCAL_USER=neo4j
NEO4J_LOCAL_PASS=secret12345

# --- 3. Рядки підключення (Connection Strings) для Python ---

# Варіант А: Для кластера з 3-х нод (обов'язковий протокол neo4j:// для маршрутизації):
NEO4J_LOCAL_URI=neo4j://127.0.0.1:7687

# Варіант Б: Для Standalone бази (використовує прямий бінарний протокол bolt://):
# NEO4J_LOCAL_URI=bolt://127.0.0.1:7687

# --- 4. Шлях до CSV-файлів для імпорту (Data Ingestion Source) ---
# Локально (Docker): файли читаються з внутрішнього тома контейнера: file:///
# Хмара (Aura): слід прописати URL свого S3/GCS бакета: https://<bucket>.s3.amazonaws.com/
NEO4J_DATA_BASE_URL=file:///

# --- 5. Хмарні URI та Креди (Neo4j Aura) ---
NEO4J_CLOUD_URI=neo4j+s://<твій_інстанс>.databases.neo4j.io
NEO4J_CLOUD_USER=neo4j
NEO4J_CLOUD_PASS=your_cloud_password_here

# 👑 РІВЕНЬ ХМАРНОЇ ПІДПИСКИ (AURA TIER)
# 'free' - Безкоштовний (Блокує >100K, без GDS)
# 'professional' - Платний (Будь-який розмір, без GDS)
# 'ds' - Enterprise Data Science (Будь-який розмір, включено GDS)
AURA_TIER=ds

# --- 6. Kaggle API Credentials (ОПЦІОНАЛЬНО) ---
# Якщо ці поля порожні або відсутні, завантаження відбудеться напряму (без API)
KAGGLE_USERNAME=
KAGGLE_KEY=
