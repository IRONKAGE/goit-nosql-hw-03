# ==============================================================================
# MLOps & Data Engineering Enterprise EditorConfig (Task 3: Neo4j Graph Engine)
# by IRONKAGE (https://github.com/IRONKAGE)
# ==============================================================================

# Це кореневий файл (IDE не повинна шукати інші конфіги вище по дереву папок)
root = true

# ------------------------------------------------------------------------------
# БАЗОВІ ПРАВИЛА ДЛЯ ВСІХ ФАЙЛІВ
# ------------------------------------------------------------------------------
[*]
charset = utf-8
# Завжди додавати порожній рядок в кінці файлу (стандарт POSIX)
insert_final_newline = true
# Автоматично видаляти зайві пробіли в кінці рядків (щоб Git diff був чистим)
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# 🔥 КРИТИЧНО ДЛЯ DOCKER/PODMAN: Завжди використовувати Linux-переноси рядків (LF)
# Якщо Windows-розробник збереже файл з CRLF, контейнер або скрипт впаде
end_of_line = lf

# ------------------------------------------------------------------------------
# СЕКРЕТИ ТА ENV-ФАЙЛИ (.env)
# ------------------------------------------------------------------------------
[{.env,*.env,.env.*}]
# LF критично важливий для Docker та bash-скриптів, які парсять .env файли
# Забороняємо автоматичне вирівнювання, щоб не зламати ключі доступу
end_of_line = lf
indent_style = space
indent_size = 2

# ------------------------------------------------------------------------------
# PYTHON (Скрипти, ETL-ядро, Streamlit)
# ------------------------------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4
# Максимальна довжина рядка (стандарт PEP8 - 88 або 119 для ML/Data Science)
max_line_length = 119

# ------------------------------------------------------------------------------
# CYPHER QUERIES (Neo4j Graph Database)
# Compatible with Neo4j 2026.04 and Cypher 25 (GQL) standards
# ------------------------------------------------------------------------------
[*.cypher]
indent_style = space
indent_size = 2
# Для графових запитів (MATCH ... WITH ... WHERE ... RETURN) 2 пробіли
# є індустріальним стандартом, щоб багаторядкові вкладення легко читалися
max_line_length = 150
# Вимикаємо примусовий додаток, оскільки плагін Neo4j його видаляє
insert_final_newline = false

# ------------------------------------------------------------------------------
# ІНФРАСТРУКТУРА ТА КОНФІГИ (Docker, YAML, JSON, TOML, INI)
# ------------------------------------------------------------------------------
[*.{yml,yaml,json,toml,ini,cfg,conf,ipynb}]
indent_style = space
indent_size = 2

[Dockerfile*]
indent_style = space
indent_size = 4

# ------------------------------------------------------------------------------
# ДАНІ ТА ДАТАСЕТИ (CSV, TSV, DAT)
# ------------------------------------------------------------------------------
[*.{csv,tsv,dat}]
# КРИТИЧНО ДЛЯ ДАНИХ (особливо MovieLens .dat файлів):
# Забороняємо видаляти "зайві" пробіли в кінці, оскільки вони можуть
# бути значущою частиною назви фільму або категорії
trim_trailing_whitespace = false
# Забороняємо додавати порожній рядок в кінці, щоб LOAD CSV не згенерував
# фантомний вузол (null) у базі графа
insert_final_newline = false

# ------------------------------------------------------------------------------
# ДОКУМЕНТАЦІЯ (Markdown, TXT)
# ------------------------------------------------------------------------------
[*.{md,txt}]
indent_style = space
indent_size = 2
# КРИТИЧНО: У Markdown два пробіли в кінці рядка означають жорсткий перенос рядка (<br>)
# Якщо IDE автоматично видалить їх (trim_trailing_whitespace), форматування зламається!
trim_trailing_whitespace = false

# ------------------------------------------------------------------------------
# MAKEFILES (Оркестрація інфраструктури)
# ------------------------------------------------------------------------------
[{Makefile,makefile}]
# Makefiles вимагають ВИКЛЮЧНО таби. Пробіли їх зламають (Error: missing separator)
indent_style = tab
# Відключаємо перевірку довжини рядка для консольних команд
max_line_length = off
